programa {     funcao inicio()     {         inteiro energia = 100         inteiro progresso = 0         inteiro opcao         inteiro kitMedico = 2         inteiro energetico = 2         inteiro mapa = 1         inteiro granada = 1         escreva("=================================\n")         escreva(" SOBREVIVENCIA ZUMBI\n")         escreva("=================================\n")         enquanto (energia > 0 e progresso < 100)         {             escreva("\nEnergia: ", energia)             escreva("\nProgresso: ", progresso, "%\n")             escreva("\n1 - Correr")             escreva("\n2 - Se esconder")             escreva("\n3 - Usar item")             escreva("\nEscolha: ")             leia(opcao)             se(opcao == 1)             {                 progresso = progresso + 20                 energia = energia - 15                 escreva("\nVoce correu dos zumbis!")             }             senao se(opcao == 2)             {                 energia = energia + 10                 se(energia > 100)                 {                     energia = 100                 }                 escreva("\nVoce encontrou um esconderijo.")             }             senao se(opcao == 3)             {                 inteiro item                 escreva("\n1 - Kit Medico (", kitMedico, ")")                 escreva("\n2 - Energetico (", energetico, ")")                 escreva("\n3 - Mapa (", mapa, ")")                 escreva("\n4 - Granada (", granada, ")")                 escreva("\nEscolha o item: ")                 leia(item)                 se(item == 1)                 {                     se(kitMedico > 0)                     {                         energia = energia + 30                         kitMedico--                         escreva("\nVida recuperada!")                     }                     senao                     {                         escreva("\nKit Medico esgotado!")                     }                 }                 senao se(item == 2)                 {                     se(energetico > 0)                     {                         energia = energia + 20                         energetico--                         escreva("\nEnergia recuperada!")                     }                     senao                     {                         escreva("\nEnergetico esgotado!")                     }                 }                 senao se(item == 3)                 {                     se(mapa > 0)                     {                         progresso = progresso + 25                         mapa--                         escreva("\nO mapa mostrou um atalho!")                     }                     senao                     {                         escreva("\nMapa esgotado!")                     }                 }                 senao se(item == 4)                 {                     se(granada > 0)                     {                         progresso = progresso + 40                         granada--                         escreva("\nA granada abriu caminho entre os zumbis!")                     }                     senao                     {                         escreva("\nGranada esgotada!")                     }                 }             }         }         se(progresso >= 100)         {             escreva("\n=================================\n")             escreva(" VITORIA!\n")             escreva(" Voce chegou ao helicoptero e escapou!\n")             escreva("=================================\n")         }         senao         {             escreva("\n=================================\n")             escreva(" GAME OVER!\n")             escreva(" Os zumbis venceram...\n")             escreva("=================================\n")         }     } }
 